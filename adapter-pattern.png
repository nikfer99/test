				<div
					style="float:right;padding:4px;margin:4px;border:1px solid #555;background-color:#B7CBD5;width:308px;min-height:250px;">

					<script async src="//pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>
					<!-- oodesign-resp-home1 -->
